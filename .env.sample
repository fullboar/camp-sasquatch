# Copy to .env.local and fill in your own values.
#   cp .env.sample .env.local
#
# .env.local is gitignored — never commit real credentials.
# Next.js does not hot-reload this file; restart the dev server after edits.

# --- Traction tenant -------------------------------------------------------

TRACTION_BASE_URL=https://traction-sandbox-tenant-proxy.apps.silver.devops.gov.bc.ca
TRACTION_TENANT_ID=your-tenant-uuid
TRACTION_API_KEY=your-tenant-api-key

# Label the wallet shows when the connection is offered.
VERIFIER_LABEL=Camp Sasquatch

# --- Proof request ---------------------------------------------------------

# Attachment format: indy | anoncreds
#   indy      -> hlindy/proof-req@v2.0      (default; the only format seen to
#                                            return a presentation from BC Wallet)
#   anoncreds -> anoncreds/proof-request@v1.0
PROOF_FORMAT=indy

# What the requested credential is pinned to: creddef | schema
# The Digital Services Card is still published on-ledger under its former "Person"
# name, so these identifiers keep it.
#   creddef -> 7xjfawcnyTUcduWVysLww5:3:CL:28075:PersonSIT  (schema Person 1.0)
#   schema  -> QEquAHkM35w4XVT3Ku5yat:2:Person:2.0          (schema Person 2.0)
RESTRICT_BY=creddef

# Demand a non-revocation proof. Needed for revocable credentials, which
# otherwise return a rev_reg_id with a null timestamp. Set false if the wallet
# can't satisfy the interval (non-revocable credential, or no tails access).
REQUIRE_NON_REVOKED=true

# --- Demo behaviour --------------------------------------------------------

# DEMO ONLY. Unlock the resident discount on a credential that was presented but
# never cryptographically verified. See "Known limitation" in the README.
# The success panel still says the signature was not checked. Set false for
# honest behaviour; never enable outside a demo.
DEMO_TRUST_PRESENTED=true

# --- Webhooks (optional) ---------------------------------------------------

# Shared secret for the webhook receiver. Appended to the registered webhook URL
# as a #fragment; ACA-Py returns it as the x-api-key header. Leave blank to
# accept unauthenticated webhooks.
WEBHOOK_API_KEY=change-me
